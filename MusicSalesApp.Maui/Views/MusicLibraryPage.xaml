<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:MusicSalesApp.Maui.ViewModels"
             x:Class="MusicSalesApp.Maui.Views.MusicLibraryPage"
             x:DataType="vm:MusicLibraryViewModel"
             Title="Music Library"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Filter Bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,*,Auto"
              ColumnSpacing="8"
              Padding="8,8,8,4"
              BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

            <!-- Genre Picker -->
            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}">
                <Picker x:Name="GenrePicker"
                        Title="All Genres"
                        ItemsSource="{Binding AvailableGenres}"
                        SelectedItem="{Binding SelectedGenre}"
                        FontSize="13"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        TitleColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                        HorizontalOptions="Fill" />
            </Border>

            <!-- Artist Picker -->
            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    Padding="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}">
                <Picker x:Name="ArtistPicker"
                        Title="All Artists"
                        ItemsSource="{Binding AvailableArtists}"
                        SelectedItem="{Binding SelectedArtist}"
                        FontSize="13"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        TitleColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                        HorizontalOptions="Fill" />
            </Border>

            <!-- Clear Filters Button -->
            <Button Grid.Column="2"
                    Command="{Binding ClearFiltersCommand}"
                    Text="✕"
                    FontSize="14"
                    HeightRequest="36"
                    WidthRequest="36"
                    Padding="0"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Song List -->
        <RefreshView x:Name="SongsRefreshView"
                     Grid.Row="1"
                     IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Songs}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Padding="20">
                        <Label Text="No songs available"
                               FontSize="18"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               TextColor="Red"
                               IsVisible="{Binding ErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SongDto">
                        <Border Margin="8,4"
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}">
                            <Grid ColumnDefinitions="80,*,Auto"
                                  ColumnSpacing="12"
                                  RowDefinitions="Auto,Auto,Auto,Auto"
                                  RowSpacing="2">

                                <!-- Album Art -->
                                <Border Grid.RowSpan="4"
                                        Grid.Column="0"
                                        StrokeShape="RoundRectangle 4"
                                        StrokeThickness="0"
                                        HeightRequest="80"
                                        WidthRequest="80"
                                        VerticalOptions="Start">
                                    <Image Source="{Binding AlbumArtUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="80"
                                           WidthRequest="80" />
                                </Border>

                                <!-- Song Title -->
                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding SongTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />

                                <!-- Artist Name (with optional persona image) -->
                                <HorizontalStackLayout Grid.Row="1"
                                                        Grid.Column="1"
                                                        Grid.ColumnSpan="2"
                                                        Spacing="6">
                                    <Border StrokeShape="RoundRectangle 10"
                                            StrokeThickness="0"
                                            HeightRequest="20"
                                            WidthRequest="20"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding PersonaImageUrl, Converter={toolkit:IsNotNullConverter}}">
                                        <Image Source="{Binding PersonaImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="20"
                                               WidthRequest="20" />
                                    </Border>
                                    <Label Text="{Binding ArtistName}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <!-- Genre · Stream Count · Song Length -->
                                <HorizontalStackLayout Grid.Row="2"
                                                        Grid.Column="1"
                                                        Grid.ColumnSpan="2"
                                                        Spacing="4">
                                    <Label Text="{Binding Genre}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}" />
                                    <Label Text="·"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}" />
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}">
                                        <Label.Text>
                                            <Binding Path="StreamCount"
                                                     StringFormat="{}{0:N0} streams" />
                                        </Label.Text>
                                    </Label>
                                    <Label Text="·"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}" />
                                    <Label x:Name="TrackLengthLabel"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}"
                                           Text="{Binding TrackLengthSeconds, Converter={StaticResource DurationConverter}}" />
                                </HorizontalStackLayout>

                                <!-- Like/Dislike buttons + Play button -->
                                <Grid Grid.Row="3"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="2"
                                      ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto"
                                      ColumnSpacing="6"
                                      Margin="0,4,0,0">

                                    <!-- Like Button -->
                                    <Button Grid.Column="0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=LikeSongCommand}"
                                            CommandParameter="{Binding .}"
                                            Text="👍"
                                            FontSize="16"
                                            HeightRequest="32"
                                            WidthRequest="32"
                                            Padding="0"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            VerticalOptions="Center" />

                                    <!-- Like Count -->
                                    <Label Grid.Column="1"
                                           Text="{Binding LikeCount}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource LikeButtonDarkText}}"
                                           VerticalOptions="Center" />

                                    <!-- Dislike Button -->
                                    <Button Grid.Column="2"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=DislikeSongCommand}"
                                            CommandParameter="{Binding .}"
                                            Text="👎"
                                            FontSize="16"
                                            HeightRequest="32"
                                            WidthRequest="32"
                                            Padding="0"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            VerticalOptions="Center" />

                                    <!-- Dislike Count -->
                                    <Label Grid.Column="3"
                                           Text="{Binding DislikeCount}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource LikeButtonDarkText}}"
                                           VerticalOptions="Center" />

                                    <!-- Play Button -->
                                    <Button Grid.Column="5"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=PlaySongCommand}"
                                            CommandParameter="{Binding .}"
                                            Text="&#x25B6;"
                                            TextColor="Black"
                                            FontSize="18"
                                            HeightRequest="40"
                                            WidthRequest="40"
                                            Padding="0"
                                            CornerRadius="20"
                                            BackgroundColor="{StaticResource Primary}"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Now Playing Bar -->
        <Border Grid.Row="2"
                Padding="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource CardBackgroundDark}}"
                StrokeThickness="0"
                IsVisible="{Binding CurrentlyPlayingSong, Converter={toolkit:IsNotNullConverter}}">
            <VerticalStackLayout Spacing="0">
                <!-- Progress Slider Row -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Padding="12,8,12,0">
                    <Label Grid.Column="0"
                           Text="{Binding FormattedPosition}"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource StreamIconDark}}"
                           VerticalOptions="Center" />
                    <Slider Grid.Column="1"
                            x:Name="ProgressSlider"
                            Minimum="0"
                            Maximum="1"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource ProgressTrack}}"
                            ThumbColor="{StaticResource Primary}"
                            VerticalOptions="Center" />
                    <Label Grid.Column="2"
                           Text="{Binding FormattedDuration}"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource StreamIconDark}}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Song Info + Controls Row -->
                <Grid ColumnDefinitions="48,*,Auto,Auto"
                      ColumnSpacing="12"
                      Padding="12,4,12,8">

                    <!-- Mini Album Art -->
                    <Border StrokeShape="RoundRectangle 6"
                            StrokeThickness="0"
                            HeightRequest="48"
                            WidthRequest="48">
                        <Image Source="{Binding CurrentlyPlayingSong.AlbumArtUrl}"
                               Aspect="AspectFill"
                               HeightRequest="48"
                               WidthRequest="48" />
                    </Border>

                    <!-- Song Info -->
                    <VerticalStackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="{Binding CurrentlyPlayingSong.SongTitle}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                        <Label Text="{Binding CurrentlyPlayingSong.ArtistName}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                    </VerticalStackLayout>

                    <!-- Play/Pause Button -->
                    <Button Grid.Column="2"
                            Command="{Binding TogglePlayPauseCommand}"
                            Text="{Binding IsPlaying, Converter={StaticResource PlayPauseGlyphConverter}}"
                            TextColor="Black"
                            FontSize="18"
                            HeightRequest="40"
                            WidthRequest="40"
                            Padding="0"
                            CornerRadius="20"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center" />

                    <!-- Stop Button -->
                    <Button Grid.Column="3"
                            Command="{Binding StopCommand}"
                            Text="&#x25A0;"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            FontSize="16"
                            HeightRequest="40"
                            WidthRequest="40"
                            Padding="0"
                            CornerRadius="20"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- MediaElement for audio playback (hidden) -->
        <toolkit:MediaElement x:Name="AudioPlayer"
                              IsVisible="false"
                              ShouldAutoPlay="True"
                              ShouldKeepScreenOn="False" />
    </Grid>

</ContentPage>
