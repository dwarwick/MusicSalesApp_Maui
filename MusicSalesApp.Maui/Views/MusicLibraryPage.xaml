<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:MusicSalesApp.Maui.ViewModels"
             xmlns:views="clr-namespace:MusicSalesApp.Maui.Views"
             x:Class="MusicSalesApp.Maui.Views.MusicLibraryPage"
             x:DataType="vm:MusicLibraryViewModel"
             Title="Music Library"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <!-- Filter Pill Bar -->
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="8"
                               Padding="8,8,8,4">

            <!-- Genre Pill -->
            <Button Command="{Binding ToggleGenrePanelCommand}"
                    Text="{Binding GenrePillText}"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Padding="14,0"
                    CornerRadius="18"
                    BackgroundColor="{Binding HasActiveGenreFilters, Converter={StaticResource ActivePillBgConverter}}"
                    TextColor="{Binding HasActiveGenreFilters, Converter={StaticResource ActivePillTextConverter}}" />

            <!-- Artist Pill -->
            <Button Command="{Binding ToggleArtistPanelCommand}"
                    Text="{Binding ArtistPillText}"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="36"
                    Padding="14,0"
                    CornerRadius="18"
                    BackgroundColor="{Binding HasActiveArtistFilters, Converter={StaticResource ActivePillBgConverter}}"
                    TextColor="{Binding HasActiveArtistFilters, Converter={StaticResource ActivePillTextConverter}}" />

            <!-- Clear Filters Button -->
            <Button Command="{Binding ClearFiltersCommand}"
                    Text="✕"
                    FontSize="14"
                    HeightRequest="36"
                    WidthRequest="36"
                    Padding="0"
                    CornerRadius="18"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                    VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Expandable Filter Panel -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsGenrePanelOpen}"
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                StrokeThickness="1"
                Margin="8,0,8,4"
                Padding="8"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}"
                MaximumHeightRequest="260">
            <VerticalStackLayout Spacing="4">
                <SearchBar Placeholder="Search genres..."
                           Text="{Binding GenreSearchText}"
                           FontSize="13"
                           HeightRequest="36"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource Primary}" />
                <CollectionView ItemsSource="{Binding GenreFilterItems}"
                                SelectionMode="None"
                                MaximumHeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FilterItem">
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,6" ColumnSpacing="8">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=ToggleGenreFilterCommand}"
                                        CommandParameter="{Binding Name}" />
                                </Grid.GestureRecognizers>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}"
                                          Color="{StaticResource Primary}"
                                          InputTransparent="True"
                                          VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2"
                                       Text="{Binding Count}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                IsVisible="{Binding IsArtistPanelOpen}"
                StrokeShape="RoundRectangle 8"
                Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                StrokeThickness="1"
                Margin="8,0,8,4"
                Padding="8"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardBackgroundDark}}"
                MaximumHeightRequest="260">
            <VerticalStackLayout Spacing="4">
                <SearchBar Placeholder="Search artists..."
                           Text="{Binding ArtistSearchText}"
                           FontSize="13"
                           HeightRequest="36"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource Primary}" />
                <CollectionView ItemsSource="{Binding ArtistFilterItems}"
                                SelectionMode="None"
                                MaximumHeightRequest="200">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FilterItem">
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,6" ColumnSpacing="8">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=ToggleArtistFilterCommand}"
                                        CommandParameter="{Binding Name}" />
                                </Grid.GestureRecognizers>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=OneWay}"
                                          Color="{StaticResource Primary}"
                                          InputTransparent="True"
                                          VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2"
                                       Text="{Binding Count}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>

        <!-- Song List -->
        <RefreshView x:Name="SongsRefreshView"
                     Grid.Row="2"
                     IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Songs}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Padding="20">
                        <Label Text="No songs available"
                               FontSize="18"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               TextColor="Red"
                               IsVisible="{Binding ErrorMessage, Converter={toolkit:IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SongDto">
                        <Border Margin="8,4"
                                Padding="12"
                                StrokeShape="RoundRectangle 8"
                                Stroke="Transparent"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=OpenSongCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8">
                                <!-- Album Art (150×150) -->
                                <Border HorizontalOptions="Center"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        HeightRequest="150"
                                        WidthRequest="150">
                                    <Image Source="{Binding AlbumArtUrl}"
                                           Aspect="AspectFill"
                                           HeightRequest="150"
                                           WidthRequest="150" />
                                </Border>

                                <!-- Song Title -->
                                <Label Text="{Binding SongTitle}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"
                                       HorizontalTextAlignment="Center" />

                                <!-- Artist Name -->
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                        Spacing="6">
                                    <Border StrokeShape="RoundRectangle 10"
                                            StrokeThickness="0"
                                            HeightRequest="20"
                                            WidthRequest="20"
                                            VerticalOptions="Center"
                                            IsVisible="{Binding PersonaImageUrl, Converter={toolkit:IsNotNullConverter}}">
                                        <Image Source="{Binding PersonaImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="20"
                                               WidthRequest="20" />
                                    </Border>
                                    <Label Text="{Binding ArtistName}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <!-- Genre · Stream Count · Song Length -->
                                <HorizontalStackLayout HorizontalOptions="Center"
                                                        Spacing="4">
                                    <Label Text="{Binding Genre}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                           IsVisible="{Binding Genre, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />
                                    <Label Text="·"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}"
                                           IsVisible="{Binding Genre, Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}">
                                        <Label.Text>
                                            <Binding Path="StreamCount"
                                                     StringFormat="{}{0:N0} streams" />
                                        </Label.Text>
                                    </Label>
                                    <Label Text="·"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}" />
                                    <Label FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource StreamIconLight}, Dark={StaticResource StreamIconDark}}"
                                           Text="{Binding TrackLengthSeconds, Converter={StaticResource DurationConverter}}" />
                                </HorizontalStackLayout>

                                <!-- Like/Dislike + Share + Play -->
                                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto"
                                      ColumnSpacing="6"
                                      HorizontalOptions="Center">

                                    <!-- Like Button -->
                                    <Grid Grid.Column="0" HeightRequest="32" WidthRequest="32">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=LikeSongCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Path Data="{Binding UserLikeStatus, Converter={StaticResource LikeGlyphConverter}}"
                                              Fill="{Binding UserLikeStatus, Converter={StaticResource LikeFillConverter}}"
                                              Aspect="Uniform"
                                              HeightRequest="18" WidthRequest="18"
                                              HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Like Count -->
                                    <Label Grid.Column="1"
                                           Text="{Binding LikeCount}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource LikeButtonDarkText}}"
                                           VerticalOptions="Center" />

                                    <!-- Dislike Button -->
                                    <Grid Grid.Column="2" HeightRequest="32" WidthRequest="32">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=DislikeSongCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Path Data="{Binding UserLikeStatus, Converter={StaticResource DislikeGlyphConverter}}"
                                              Fill="{Binding UserLikeStatus, Converter={StaticResource DislikeFillConverter}}"
                                              Aspect="Uniform"
                                              HeightRequest="18" WidthRequest="18"
                                              HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Dislike Count -->
                                    <Label Grid.Column="3"
                                           Text="{Binding DislikeCount}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource LikeButtonDarkText}}"
                                           VerticalOptions="Center" />

                                    <!-- Facebook Share Button -->
                                    <views:FacebookShareButton Grid.Column="4"
                                                               ShareUrl="{Binding ShareUrl}"
                                                               VerticalOptions="Center" />

                                    <!-- Share Button -->
                                    <views:ShareButton Grid.Column="5"
                                                       ShareTitle="{Binding SongTitle}"
                                                       ShareUrl="{Binding ShareUrl}"
                                                       VerticalOptions="Center" />

                                    <!-- Play Button -->
                                    <Button Grid.Column="7"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MusicLibraryViewModel}}, Path=PlaySongCommand}"
                                            CommandParameter="{Binding .}"
                                            Text="&#x25B6;"
                                            TextColor="Black"
                                            FontSize="18"
                                            HeightRequest="40"
                                            WidthRequest="40"
                                            Padding="0"
                                            CornerRadius="20"
                                            BackgroundColor="{StaticResource Primary}"
                                            VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Now Playing Bar (reusable component) -->
        <views:NowPlayingView x:Name="NowPlayingBar"
                              Grid.Row="3" />

        <!-- MediaElement for audio playback (hidden) -->
        <toolkit:MediaElement x:Name="AudioPlayer"
                              Grid.Row="4"
                              IsVisible="false"
                              ShouldAutoPlay="True"
                              ShouldKeepScreenOn="False" />
    </Grid>

</ContentPage>
